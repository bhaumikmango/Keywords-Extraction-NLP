# ── KeyExtract Backend — Environment Variables ────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Flask ─────────────────────────────────────────────────────────────────
FLASK_DEBUG=0
PORT=5000

# ── Model source ──────────────────────────────────────────────────────────
# Use "local" to load .pkl files from disk (default)
# Use "mlflow" to pull from MLflow model registry
MODEL_SOURCE=local

# ── MLflow (only needed when MODEL_SOURCE=mlflow) ─────────────────────────
# DagsHub free tier: https://dagshub.com/<your-user>/<your-repo>.mlflow
MLFLOW_TRACKING_URI=mlruns
MLFLOW_EXPERIMENT_NAME=keyword-extractor
MLFLOW_MODEL_NAME=keyword-extractor-tfidf
MLFLOW_MODEL_STAGE=Production

# DagsHub credentials (generate a token at https://dagshub.com/user/settings/tokens)
MLFLOW_TRACKING_USERNAME=
MLFLOW_TRACKING_PASSWORD=
